{
    "name": "gamescript-vscode",
    "displayName": "GameScript Workspace Support",
    "description": "Adds syntax highlighting, IntelliSense, and diagnostics for the GameScript language in Vscode.",
    "version": "1.3.0",
    "publisher": "YeOldeGames",
    "engines": {
        "vscode": "^1.90.0"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^22.15.17",
        "@types/vscode": "^1.90.0",
        "typescript": "^5.4.5"
    },
    "homepage": "https://github.com/Juiix/GameScript/blob/main/GameScript.VisualStudio/overview.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/Juiix/GameScript"
    },
    "contributes": {
        "languages": [
            {
                "id": "gamescript",
                "aliases": [
                    "Game Script",
                    "gamescript"
                ],
                "extensions": [
                    ".gs",
                    ".const",
                    ".context"
                ],
                "configuration": "./resources/gamescript-configuration.json",
                "icon": {
                  "light": "./images/gamescript.png",
                  "dark": "./images/gamescript.png"
                }
            },
            {
                "id": "objectdef",
                "aliases": ["Object Definition", "objectdef"],
                "extensions": [
                  ".varp",
                  ".item",
                  ".npc",
                  ".menu",
                  ".obj",
                  ".tile",
                  ".inv"
                ],
                "configuration": "./resources/objectdef-configuration.json",
                "icon": {
                  "light": "./images/objectdef.png",
                  "dark": "./images/objectdef.png"
                }
            }
        ],
        "grammars": [
          {
            "language": "gamescript",
            "scopeName": "source.gamescript",
            "path": "./syntaxes/gamescript.tmLanguage.json"
          },
          {
            "language": "objectdef",
            "scopeName": "source.objectdef",
            "path": "./syntaxes/objectdef.tmLanguage.json"
          }
        ],
        "configurationDefaults": {
            "[gamescript]": {
                "editor.tabSize": 4
            },
            "[objectdef]": {
                "editor.tabSize": 4
            }
        },
        "breakpoints": [
            { "language": "gamescript" }
        ],
        "debuggers": [
            {
                "type": "gamescript",
                "label": "GameScript",
                "languages": ["gamescript"],
                "configurationAttributes": {
                    "attach": {
                        "required": ["port"],
                        "properties": {
                            "port": {
                                "type": "number",
                                "description": "TCP port the game's DAP server is listening on.",
                                "default": 4711
                            },
                            "host": {
                                "type": "string",
                                "description": "Hostname of the game process.",
                                "default": "127.0.0.1"
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "gamescript",
                        "request": "attach",
                        "name": "Attach to Game",
                        "port": 4711,
                        "host": "127.0.0.1"
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "GameScript: Attach to Game",
                        "description": "Attach the VS Code debugger to a running game process.",
                        "body": {
                            "type": "gamescript",
                            "request": "attach",
                            "name": "Attach to Game",
                            "port": 4711,
                            "host": "127.0.0.1"
                        }
                    }
                ]
            }
        ]
    },
    "main": "./out/extension.js",
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "prepublish": "npm run compile"
    }
}
